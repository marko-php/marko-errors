{
    "name": "marko/errors",
    "description": "Marko Framework Error Handling",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Errors\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Errors\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
